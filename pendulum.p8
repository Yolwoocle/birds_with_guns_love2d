pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
function new_pend(x,y,l)
    local a0 = a0 or 0
    return {
        mass = 1,
        len = l,
        resist = 0.96,
 
        x = x,
        y = y,
        x2 = x,
        y2 = y+l,

        g = 0.05,

        a = 0,
        a_vel = 0,
        a_acc = 0,
        a_acc_add = 0, --a_acc that other functions can *add* onto

        forces = {},
        compute_extremity = function(self) 
            self.x2 = self.x + cos(self.a-0.25)*self.len
            self.y2 = self.y + sin(self.a-0.25)*self.len
        end,

        theta_component = function(self, vx, vy)
            return -vx*sin(self.a+0.25) + vy*cos(self.a+0.25)
        end,

        update = function(self, dt)
            -- self.forces = {}
            -- add(self.forces, {0, self.mass*self.g})
            -- local f = {0, 0}
            -- for i=1, #self.forces do
            --     f[1] += self.forces[i][1]
            --     f[2] += self.forces[i][2]
            -- end
            -- Project onto theta axis
            local acc = self.g*sin(self.a) - self.a_vel*self.resist + self.a_acc_add
            self.a_acc_add = 0
            
            -- Apply transform
            self.a_acc = acc * dt
            self.a_vel += self.a_acc
            self.a += self.a_vel
            
            -- Compute extremity position
            self:compute_extremity()
        end,

        draw = function(self)
            line(self.x, self.y, self.x2, self.y2, 8)
            circfill(self.x2, self.y2, 2, 8)
            
        end
    }
end

function draw_vect(x1, y1, x2, y2, col)
    local a = atan2(x2-x1, y2-y1) + 0.5
    local l = 2
    local o = 1/8

    color(col)
    line(x1, y1, x2, y2)
    line(x2, y2, x2+cos(a-o)*l, y2+sin(a-o)*l)
    line(x2, y2, x2+cos(a+o)*l, y2+sin(a+o)*l)
end

local pend = new_pend(64,64,30)
pend.a = 0
pend.g = 0.05
-- pend.a_vel = 0.1 

local mx, my = 0, 0
local lmb, rmb = false, false
local mx_vel, my_vel = 0, 0
local debug = 0

local past_angles = {0,0,0,0,0}
local trail_palette = {[0]=0, 128, 130, 133, 5, 13, 134, 6, 7}
for i=0, #trail_palette do pal(i, trail_palette[i], 1) end    

function _init()
    
end

local dt = 1/60
function _update60()
    poke(0x5F2D, 1)
    mx_vel = stat(32) - mx
    my_vel = stat(33) - my
    mx = stat(32)
    my = stat(33)
    lmb = stat(34)&1 == 1
    rmb = stat(34)&2 == 1

    if lmb then
        local dx, dy = pend.x-mx, pend.y-my
        local a = atan2(dx, dy)
        pend.a_acc = 0
        pend.a_vel = 0
        pend.a = a-0.25
        pend:compute_extremity()
        
        local acc = pend:theta_component(mx_vel*5, my_vel*5) / pend.len
        debug = acc
        pend.a_acc_add = acc
    else
        pend:update(dt)
    end

    add(past_angles, pend.a)
    if #past_angles > #trail_palette-1 then
        del(past_angles, past_angles[1])
    end
end

function _draw()
    cls()
    map()

    for i=1, #past_angles do
        local a = past_angles[i]
        local x2 = pend.x + cos(a-0.25)*pend.len
        local y2 = pend.y + sin(a-0.25)*pend.len
        line(pend.x, pend.y, x2, y2, i)
        circfill(x2, y2, 2, i)
    end

    pend:draw()
    
    spr(lmb and 2 or 1, mx, my)
    -- print(debug, 0, 0)

    -- draw_vect(mx, my, mx+mx_vel, my+my_vel, 11)
    local m =10
    -- draw_vect(pend.x2, pend.y2, 
    --     pend.x2+cos(pend.a)*pend.len * pend.a_vel * m, 
    --     pend.y2+sin(pend.a)*pend.len * pend.a_vel * m, 
    -- 8)
end

